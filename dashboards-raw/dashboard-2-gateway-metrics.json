  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "code",
          "expr": "system_cpu_usage{job=\"$application\"} * 100",
          "legendFormat": "{{job}} - CPU",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "percent"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "JVM Heap Memory (MB)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "code",
          "expr": "jvm_memory_used_bytes{job=\"$application\",area=\"heap\"} / 1024 / 1024",
          "legendFormat": "{{job}} - Heap Used",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "code",
          "expr": "jvm_memory_max_bytes{job=\"$application\",area=\"heap\"} / 1024 / 1024",
          "legendFormat": "{{job}} - Heap Max",
          "range": true,
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "decbytes"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "JVM Active Threads",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "code",
          "expr": "jvm_threads_live_threads{job=\"$application\"}",
          "legendFormat": "{{job}} - Threads",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "short"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "id": 4,
      "title": "GC Total Pause Duration (ms)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "code",
          "expr": "sum(increase(jvm_gc_pause_seconds_sum{job=\"$application\"}[5m])) * 1000",
          "legendFormat": "{{job}} - GC Pause Time",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "ms"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "id": 5,
      "title": "Request Rate & Latency",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-ds"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"$application\"}[5m]))",
          "legendFormat": "Requests/sec",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-ds"
          },
          "editorMode": "code",
          "expr": "(sum(rate(http_server_requests_seconds_sum{job=\"$application\"}[5m])) / sum(rate(http_server_requests_seconds_count{job=\"$application\"}[5m]))) * 1000",
          "legendFormat": "Avg Response Time (ms)",
          "range": true,
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          }
        }
      }
    }
  ],
